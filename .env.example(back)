# Copy this file to backend/.env and replace every placeholder with your own value.
# Never commit or share backend/.env.

# Required: database, authentication, and server-side encryption
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ENCRYPTION_KEY=your_fernet_encryption_key

# Required when AI chatbot or AI summaries are enabled
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# Optional: market data and news providers
TOSS_API_KEY=
TOSS_SECRET_KEY=
KIS_APPKEY=
KIS_APPSECRET=
KIS_CANO=
KIS_ACNT_PRDT_CD=
KIS_ENV=MOCK/REAL
COINONE_SECRET_KEY=
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
FINNHUB_API_KEY=
DART_API_KEY=
TAVILY_API_KEY=

# Optional: scheduling and automation
ML_AUTOMATION_ENABLED=false
NEWS_INGEST_ENABLED=false
DART_INGEST_ENABLED=false
HOME_MARKET_SNAPSHOT_ENABLED=true

# Optional: chatbot limits and model configuration
CHATBOT_DAILY_TOKEN_LIMIT=100000
CHATBOT_MAX_HISTORY_MESSAGES=20
CHATBOT_MAX_INPUT_CHARS=12000
CHATBOT_MAX_OUTPUT_TOKENS=2000
CHATBOT_MAX_TOOL_ROUNDS=6
CHATBOT_TEMPERATURE=0.2
CHATBOT_PRIMARY_PROVIDER=openai
CHATBOT_PRIMARY_MODEL=gpt-4o-mini
CHATBOT_FALLBACK_PROVIDER=google
CHATBOT_FALLBACK_MODEL=gemini-2.0-flash

# Optional: worker execution mode
WORKER_MODE=disabled
