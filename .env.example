# 1. D:\KDH\Trading\backend\.env
#    Flask 백엔드/백엔드 스크립트가 읽는 비밀키와 서버 설정입니다.

# 2. D:\KDH\Trading\frontend\.env
#    Vite React 프론트엔드가 읽는 공개 설정입니다.

# 절대 주의:
# - frontend/.env에는 VITE_ 로 시작하는 값만 넣습니다.
# - SUPABASE_SERVICE_ROLE_KEY, 거래소 Secret, OPENAI_API_KEY는 프론트에 넣지 않습니다.


# =============================================================================
# backend/.env
# =============================================================================

# Core security
ENCRYPTION_KEY=replace-me

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me

# 백엔드 관리자 권한 키입니다. 절대 frontend/.env에 넣지 않습니다.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# 모의투자 경우에 
#KIS_APPKEY=모의투자 키 넣어야 합니다!!
#KIS_APPSECRET=모의투자 키 넣어야 합니다!!
#KIS_CANO=모의투자 키 넣어야 합니다!!
#KIS_ENV=MOCK (실제 키 사용하시면 REAL로 바꾸기)

# KIS / Korea Investment Securities / 한국투자증권
KIS_APPKEY=replace-me
KIS_APPSECRET=replace-me
KIS_CANO=replace-me (한투 계좌번호)
KIS_ACNT_PRDT_CD=01
KIS_ENV=MOCK

# 홈 해외주식 랭킹 캐시에 사용할 미국 종목 후보입니다. 비워두면 코드 기본 후보군을 사용합니다.
KIS_US_RANK_SYMBOLS=
KIS_US_RANK_SCAN_LIMIT=50

# Toss Securities / 토스증권
TOSS_API_KEY=replace-me
TOSS_SECRET_KEY=replace-me

# Coinone / 코인원
COINONE_ACCESS_TOKEN=replace-me
COINONE_SECRET_KEY=replace-me

# Binance / 바이낸스
BINANCE_API_KEY=replace-me
BINANCE_SECRET_KEY=replace-me
# 바이낸스 USD-M 선물 REAL 주문 잠금 해제 플래그입니다. 기본값 false를 유지하고 충분한 모의 검증 후에만 true로 변경하십시오.
BINANCE_FUTURES_REAL_ENABLED=false

# OpenAI / News RAG
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_TIMEOUT_SECONDS=30
NEWS_SUMMARY_MODEL=gpt-4o-mini
NEWS_SUMMARY_PROMPT_VERSION=v1
NEWS_SUMMARY_TIMEOUT_SECONDS=30

# OpenAI / Web chatbot
CHATBOT_MAX_INPUT_CHARS=2000
CHATBOT_MAX_OUTPUT_TOKENS=1024
CHATBOT_MAX_HISTORY_MESSAGES=16
CHATBOT_MAX_TOOL_CALLS=3
CHATBOT_MINUTE_REQUEST_LIMIT=10
CHATBOT_DAILY_TOKEN_LIMIT=50000
CHATBOT_INTERNAL_API_BASE_URL=http://localhost:5050
CHATBOT_RAG_TOP_K=5
CHATBOT_RAG_MAX_CONTEXT_CHARS=6000
CHATBOT_RAG_MATCH_THRESHOLD=0.2

# Tavily web search for chatbot
TAVILY_API_KEY=replace-me
TAVILY_SEARCH_DEPTH=basic
TAVILY_TIMEOUT_SECONDS=20
CHATBOT_TAVILY_FALLBACK_ENABLED=true
CHATBOT_WEB_SEARCH_MAX_RESULTS=5

# Naver / Finnhub news ingestion
NAVER_CLIENT_ID=replace-me
NAVER_CLIENT_SECRET=replace-me
FINNHUB_API_KEY=replace-me

# OpenDART disclosure ingestion
DART_API_KEY=replace-me
DART_INGEST_ENABLED=true
DART_INGEST_INTERVAL_SECONDS=900
DART_PAGE_COUNT=100
DART_INCREMENTAL_LOOKBACK_DAYS=1
DART_BACKFILL_DAYS=365
DART_BACKFILL_CHUNK_DAYS=1
DART_REQUEST_TIMEOUT_SECONDS=15
DART_ANALYSIS_AI_ENABLED=true
DART_ANALYSIS_AI_PROVIDER=gemini
DART_ANALYSIS_MODEL=gpt-4o-mini
DART_GEMINI_MODELS=gemini-3.5-flash,gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite
DART_GEMINI_PRIMARY_MODEL=gemini-3.5-flash
DART_GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
GEMINI_API_KEY=replace-me
DART_ANALYSIS_PROMPT_VERSION=v3
DART_ANALYSIS_TIMEOUT_SECONDS=30
DART_ANALYSIS_EXCERPT_CHARS=4000

# Knowledge RAG indexing
DISCLOSURE_RAG_BACKFILL_LIMIT=500
KNOWLEDGE_EMBEDDING_BATCH_SIZE=100
KNOWLEDGE_EMBEDDING_SOURCE_TYPE=DISCLOSURE

# Home market table cache / scheduler
HOME_STOCK_CLIENT_CACHE_LIMIT=200

# 홈 주식 표 최종 표시 개수입니다.
HOME_STOCK_LIMIT=10

# KIS 순위 API별 수집 후보 개수입니다.
HOME_MARKET_RANK_LIMIT=50

# 홈 주식 메모리 캐시 TTL입니다.
HOME_STOCK_CACHE_TTL_SECONDS=300

# 홈 주식 표에서 같은 수집 회차로 인정할 as_of 허용 범위(초)입니다.
HOME_MARKET_SNAPSHOT_COHORT_SECONDS=1800

# 코인원 홈 코인 표 표시 개수입니다.
COINONE_HOME_LIMIT=10
COINONE_RANK_MAX_LIMIT=100

# 백그라운드 홈 마켓 스냅샷 갱신 스케줄러입니다.
HOME_MARKET_SNAPSHOT_ENABLED=true
HOME_MARKET_OPEN_INTERVAL_SECONDS=60
HOME_MARKET_CLOSED_INTERVAL_SECONDS=600
HOME_MARKET_SNAPSHOT_LIMIT=300
HOME_MARKET_SNAPSHOT_WORKERS=2
HOME_US_MARKET_SNAPSHOT_ENABLED=true

# Flask API Gateway(app.py) 내부에서 백그라운드 스케줄러 스레드들을 직접 기동할지 여부입니다.
# Gunicorn 다중 워커 환경이나 개발자 로컬 분산 협업 시 false로 설정하고, 독립 worker.py 프로세스를 단독으로 띄워 스케줄러를 가동하십시오.
SCHEDULER_RUN_IN_GATEWAY=false

# 조건감시 자동/반자동 매도 스케줄러입니다.
# true로 켜면 auto_trading_rules의 RUNNING 규칙을 주기적으로 확인하고,
# execution_mode=PROPOSAL은 매도 제안만 생성하며 execution_mode=AUTO는 조건 충족 시 매도 주문을 전송합니다.
AUTO_TRADING_RULES_ENABLED=false
AUTO_TRADING_RULES_INTERVAL_SECONDS=30

# 전체 사용자 미완료 주문 상태 동기화 스케줄러입니다.
# true로 켜면 worker.py가 APPROVED/ORDERED/OPEN/PARTIALLY_FILLED/MODIFIED 주문만 주기적으로 확인해
# KIS, COINONE, BINANCE, BINANCE_UM_FUTURES 실제 주문 상태를 trade_proposals에 반영합니다.
OPEN_ORDER_STATUS_SYNC_ENABLED=false
OPEN_ORDER_STATUS_SYNC_INTERVAL_SECONDS=60
OPEN_ORDER_STATUS_SYNC_LIMIT=100

# 장 운영 캘린더 적재 스케줄러입니다.
# true로 켜면 worker.py 또는 gateway scheduler가 Toss 캘린더 API로 KR/US 오늘 장 운영 정보를 market_calendar_days에 저장합니다.
MARKET_CALENDAR_SYNC_ENABLED=false
MARKET_CALENDAR_SYNC_INTERVAL_SECONDS=86400
MARKET_CALENDAR_SYNC_ENV=REAL

# News ingestion scheduler
NEWS_INGEST_ENABLED=true
NEWS_INGEST_INTERVAL_SECONDS=600
NEWS_MAX_ITEMS_PER_QUERY=12
NEWS_CACHE_TTL_SECONDS=300
NEWS_NAVER_DAILY_QUERY_BUDGET=2000
NEWS_MAX_QUERIES_PER_RUN=30
NEWS_DYNAMIC_SYMBOLS_PER_RUN=5
NEWS_STATIC_SYMBOLS_PER_RUN=8
NEWS_QUERY_COOLDOWN_MINUTES=30
NEWS_FINNHUB_SYMBOLS=AAPL,MSFT,NVDA
NEWS_STATIC_SYMBOLS=005930,000660,035420,068270,AAPL,MSFT,NVDA,AMD

# ML automation
ML_AUTOMATION_ENABLED=true
DEVELOPER_NAME=local-dev


# =============================================================================
# frontend/.env
# =============================================================================
# 프론트엔드에서 필요한 공개 설정만 둡니다.
# Vite는 VITE_ 접두사가 붙은 값만 브라우저 코드에서 읽을 수 있습니다.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-me
VITE_API_BASE_URL=http://localhost:5050
